  volume = {27},
  number = {Supplement\_1},
  pages = {i1-i42},
  issn = {1522-8517, 1523-5866},
  doi = {10.1093/neuonc/noaf168},
  urldate = {2026-01-20},
  abstract = {Abstract             This report comprehensively describes the most up-to-date incidence of primary brain and other central nervous system (CNS) tumors in children and adolescents (ages 0-19 years old), utilizing population-based data collected and reported by central cancer registries covering 99.9\% of the United States population. Overall, brain and other CNS tumors are the most common cancer and the most common cause of cancer death in children and adolescents. This report aims to serve as a resource for researchers, clinicians, patients, and families.},
